<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # 1. EXCLUIR EL BACKEND: Si la URL empieza por backend, no hagas nada
  RewriteCond %{REQUEST_URI} ^/backend/api [NC]
  RewriteRule ^ - [L]

  # 2. REDIRECCIONAR A ANGULAR: Si no es un archivo físico ni carpeta, ve a index.html
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>